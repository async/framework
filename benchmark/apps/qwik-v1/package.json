{
  "name": "@async/framework-benchmark-app-qwik-v1",
  "version": "0.0.1",
  "description": "Qwik 1 demo",
  "main": "dist/main.js",
  "license": "Apache-2.0",
  "homepage": "https://github.com/async/framework",
  "repository": {
    "type": "git",
    "url": "https://github.com/async/framework.git"
  },
  "engines": {
    "node": ">=18.6.0"
  },
  "async-framework-benchmark": {
    "frameworkVersionFromPackage": "@builder.io/qwik",
    "frameworkHomeURL": "https://qwik.builder.io/",
    "customURL": "/dist",
    "issues": [
      1139
    ],
    "language": "TypeScript"
  },
  "scripts": {
    "build-dev": "vite --mode ssr",
    "build-prod": "rm -rf dist; qwik build && mv dist/apps/qwik-v1/dist/* dist/ && rm -rf dist/apps",
    "build": "qwik build",
    "build.client": "vite build",
    "build.preview": "vite build --ssr src/entry.preview.tsx",
    "dev": "vite --mode ssr",
    "dev.debug": "node --inspect-brk ./node_modules/vite/bin/vite.js --mode ssr --force",
    "build.server": "vite build -c adapters/static/vite.config.ts",
    "preview": "qwik build preview && vite preview --open",
    "qwik": "qwik"
  },
  "devDependencies": {
    "@builder.io/qwik": "1.19.1",
    "@builder.io/qwik-city": "1.19.2",
    "vite": "^6.4.3",
    "vite-tsconfig-paths": "^4.2.1"
  }
}
