{
  "name": "@async/framework-benchmark-app-qwik-v2",
  "version": "0.0.1",
  "description": "Qwik 2 beta demo",
  "type": "module",
  "main": "dist/main.js",
  "license": "Apache-2.0",
  "homepage": "https://github.com/async/framework",
  "repository": {
    "type": "git",
    "url": "https://github.com/async/framework.git"
  },
  "engines": {
    "node": ">=18.6.0"
  },
  "async-framework-benchmark": {
    "frameworkVersionFromPackage": "@qwik.dev/core",
    "frameworkHomeURL": "https://qwik.dev/",
    "customURL": "/dist",
    "issues": [
      1139
    ],
    "language": "TypeScript"
  },
  "scripts": {
    "build-dev": "vite --mode ssr",
    "build-prod": "rm -rf dist; qwik build && if [ -d dist/apps/qwik-v2/dist ]; then mv dist/apps/qwik-v2/dist/* dist/ && rm -rf dist/apps; fi",
    "build": "qwik build",
    "build.client": "vite build",
    "build.preview": "vite build --ssr src/entry.preview.tsx",
    "dev": "vite --mode ssr",
    "dev.debug": "node --inspect-brk ./node_modules/vite/bin/vite.js --mode ssr --force",
    "build.server": "vite build -c adapters/static/vite.config.ts",
    "preview": "qwik build preview && vite preview --open",
    "qwik": "qwik"
  },
  "devDependencies": {
    "@qwik.dev/core": "2.0.0-beta.36",
    "@qwik.dev/router": "2.0.0-beta.36",
    "vite": "8.0.16",
    "vite-tsconfig-paths": "^6.1.1"
  }
}
