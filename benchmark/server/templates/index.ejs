<!doctype html>
<html>
  <head>
    <title>Async Framework App Harness</title>
    <meta charset="UTF-8" />
    <link rel="stylesheet" href="css/tailwind.css" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
  </head>

  <body>
    <div class="min-h-screen bg-slate-50 py-8">
      <main class="mx-auto max-w-7xl px-6">
        <section class="rounded-lg border border-slate-200 bg-white p-6 shadow-sm">
          <h1 class="mb-6 text-4xl font-semibold tracking-normal text-slate-900">Async Framework App Harness</h1>
          <div class="grid grid-cols-1 gap-3 sm:grid-cols-2 lg:grid-cols-3">
            <% frameworks.forEach(framework => { %>
            <a class="rounded border border-slate-200 bg-white px-4 py-2.5 text-sky-700 transition hover:text-sky-900" href="/<%= framework.uri %>/index.html"
              ><%= framework.frameworkVersionString %>
            </a>
            <% }); %>
          </div>
        </section>
      </main>
    </div>
  </body>
</html>
