{
  "name": "@async/framework-benchmark-harness",
  "version": "1.0.0",
  "description": "Modern app and benchmark harness for @async/framework comparison work.",
  "type": "module",
  "private": true,
  "scripts": {
    "clean": "node cli.js cleanup",
    "build-apps": "node cli.js build-apps --ci -f js-only react qwik-v1 qwik-v2 solid-v1 solid-v2",
    "build": "npm run build-apps",
    "build-prod": "npm run build-apps",
    "compile": "npm run build-apps",
    "start": "cd server && npm start",
    "benchmark:run": "cd runner && node src/cli.js --mode trace",
    "benchmark:smoke": "cd runner && node src/cli.js --mode smoke",
    "benchmark:results": "cd runner && node src/results.js",
    "app-health": "cd app-health && node src/apps.js",
    "apps": "npm run build-apps && npm run app-health",
    "postinstall": "cd server && npm install",
    "install-apps": "npm run install-runner && npm run install-app-health && npm run install-server",
    "install-runner": "cd runner && npm ci && npx playwright install chromium",
    "install-app-health": "cd app-health && npm ci && npx playwright install chromium",
    "install-server": "cd server && npm ci",
    "install-local": "npm run install-apps",
    "rebuild": "node cli.js build-apps -f",
    "rebuild-ci": "node cli.js build-apps --ci -f",
    "format": "prettier . \"!(broken-frameworks|apps)/**/*\" -w",
    "lint": "eslint app-health runner cli server"
  },
  "keywords": [
    "benchmark",
    "javascript",
    "frontend",
    "client",
    "react",
    "app-health"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/async/framework.git"
  },
  "author": "Stefan Krause",
  "license": "ISC",
  "homepage": "https://github.com/async/framework",
  "dependencies": {
    "commander": "^14.0.3",
    "json5": "^2.2.3",
    "rimraf": "^6.1.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "local-web-server": "^5.4.0",
    "prettier": "^3.8.1",
    "semver": "^7.7.4",
    "typescript": "6.0.2",
    "typescript-eslint": "^8.57.2"
  }
}
