{
  "name": "@async/framework",
  "version": "0.1.0",
  "description": "Layer 1 AsyncLoader runtime with signals, async signals, delegated handlers, and out-of-order boundary swaps.",
  "type": "module",
  "packageManager": "pnpm@11.1.0",
  "engines": {
    "node": ">=24"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/async/framework.git"
  },
  "license": "MIT",
  "exports": {
    ".": "./src/index.js"
  },
  "files": [
    "src",
    "examples",
    "LICENSE",
    "package.json"
  ],
  "scripts": {
    "async-pipeline": "async-pipeline",
    "examples": "node --test tests/examples.test.js",
    "examples:check": "node --test tests/examples.test.js",
    "pack:check": "npm pack --dry-run --ignore-scripts",
    "pipeline:github:check": "async-pipeline github check",
    "pipeline:sync:check": "async-pipeline sync check",
    "pipeline:verify": "async-pipeline run verify",
    "release:check": "pnpm run pipeline:verify -- --force && pnpm run pipeline:sync:check && pnpm run pipeline:github:check",
    "test": "node --test tests/*.test.js"
  },
  "devDependencies": {
    "@async/pipeline": "0.8.5",
    "happy-dom": "20.10.5"
  }
}
