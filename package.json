{
  "name": "async-framework-workspace",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.5.2",
  "scripts": {
    "test:workspace": "node --test tests/workspace-layout.test.mjs",
    "typecheck": "pnpm --filter '@async/framework*' typecheck",
    "lint:wintercg": "eslint \"frameworks/**/*.{ts,tsx,js,mjs}\" --max-warnings=0 --no-error-on-unmatched-pattern",
    "benchmark": "tsx benchmarks/run.ts",
    "benchmark:signals": "tsx benchmarks/run.ts --scenario signals",
    "example:v0": "pnpm --filter @async/example-v0-hello-world dev",
    "example:v1": "pnpm --filter @async/example-v1-basic-local dev"
  },
  "dependencies": {
    "@async/framework-v0": "workspace:*",
    "@async/framework-v1": "workspace:*"
  },
  "devDependencies": {
    "eslint": "9.26.0",
    "tsx": "4.19.3",
    "typescript": "5.8.3",
    "typescript-eslint": "8.31.1"
  }
}
